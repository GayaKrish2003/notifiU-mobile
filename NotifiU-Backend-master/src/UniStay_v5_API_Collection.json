		{
			"name": "03. User Profile",
			"description": "Private endpoints for authenticated users to manage their own profile.",
			"item": [
				{
					"name": "Get My Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/profile",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile"]
						},
						"description": "Returns full profile with role-specific fields and profile completion percentage."
					},
					"response": []
				},
				{
					"name": "Update My Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Name\",\n    \"age\": 23,\n    \"phonenumber\": \"0771234567\",\n    \"faculty\": \"Faculty of Engineering\",\n    \"academicYear\": \"4th Year\",\n    \"profileImage\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/profile",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile"]
						},
						"description": "Update your own profile. Supports Base64 'profileImage'. Role-specific fields are only updated if your role matches."
					},
					"response": []
				},
				{
					"name": "Upload Profile Image",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "profileImage", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/users/profile/image",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "image"]
						},
						"description": "Upload a profile image. Accepts: jpeg, jpg, png, gif, webp. Max file size: 5MB. Select a file in the 'src' field."
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"password123\",\n    \"newPassword\": \"newPassword456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/profile/password",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "password"]
						},
						"description": "Change your password. Requires current password for verification. New password must be at least 8 characters."
					},
					"response": []
				},
				{
					"name": "Get Profile Completion %",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/profile/completion",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "completion"]
						},
						"description": "Returns profile completion percentage based on filled fields. Calculation is role-specific (students need university/faculty/etc, job providers need company info, etc)."
					},
					"response": []
				}
			]
		},
		{
			"name": "04. Admin - User Management",
			"description": "SuperAdmin-only endpoints for managing all users in the system.",
			"item": [
				{
					"name": "Get All Users (Search/Filter/Paginate)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users?page=1&limit=10&search=&role=all&status=all&sortBy=createdAt&order=desc",
							"host": ["{{baseUrl}}"],
							"path": ["users"],
							"query": [
								{"key": "page", "value": "1", "description": "Page number (default: 1)"},
								{"key": "limit", "value": "10", "description": "Items per page (default: 10)"},
								{"key": "search", "value": "", "description": "Search by name, email, username, or NIC"},
								{"key": "role", "value": "all", "description": "Filter: all, student, lecturer, jobprovider, superadmin"},
								{"key": "status", "value": "all", "description": "Filter: all, pending, active, suspended, deactivated"},
								{"key": "sortBy", "value": "createdAt", "description": "Sort field: createdAt, name, email, role"},
								{"key": "order", "value": "desc", "description": "Sort order: asc or desc"}
							]
						},
						"description": "SuperAdmin only. Returns paginated list of users with total count and pagination metadata."
					},
					"response": []
				},
				{
					"name": "Admin Create User",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Admin Created User\",\n    \"email\": \"admincreated@unistay.com\",\n    \"password\": \"password123\",\n    \"role\": \"student\",\n    \"university\": \"University of Moratuwa\",\n    \"address\": \"100 Test Lane\",\n    \"age\": 21,\n    \"nic\": \"200112345678\",\n    \"phonenumber\": \"0744444444\",\n    \"accountStatus\": \"active\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/admin/create",
							"host": ["{{baseUrl}}"],
							"path": ["users", "admin", "create"]
						},
						"description": "SuperAdmin manually creates a user. If password is omitted, defaults to 'TempPass123!'. Allowed roles: student, lecturer, jobprovider, superadmin."
					},
					"response": []
				},
				{
					"name": "Update User By Admin (Legacy)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated By Admin\",\n    \"role\": \"lecturer\",\n    \"accountStatus\": \"active\",\n    \"university\": \"University of Peradeniya\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}"]
						},
						"description": "SuperAdmin can update any user's details including role, status, and all profile fields."
					},
					"response": []
				},
				{
					"name": "Get User Profile By ID",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "{{userId}}"]
						},
						"description": "Admin only. Returns user profile details by MongoDB ID."
					},
					"response": []
				},
				{
					"name": "Update User Profile By ID",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Admin Corrected Name\",\n    \"email\": \"corrected@unistay.com\",\n    \"profileImage\": \"data:image/png;base64,...\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "{{userId}}"]
						},
						"description": "Admin only. Update any user's core details and profile image using Base64."
					},
					"response": []
				},
				{
					"name": "Update User Role",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"lecturer\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/role",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}", "role"]
						},
						"description": "Change a user's role. Allowed values: superadmin, student, lecturer, jobprovider."
					},
					"response": []
				},
				{
					"name": "Update Account Status",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"suspended\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}", "status"]
						},
						"description": "Change account status. Allowed values: pending, active, suspended, deactivated. Cannot suspend/deactivate superadmin accounts."
					},
					"response": []
				},
				{
					"name": "Get User Activity & Login History",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/activity",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}", "activity"]
						},
						"description": "View a user's login history (last 20 entries with IP/UserAgent), activity log (last 50 actions), and last login timestamp."
					},
					"response": []
				},
				{
					"name": "Soft Delete User (Deactivate)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}] },
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/soft",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}", "soft"]
						},
						"description": "Soft deletes user: sets isDeleted=true, deletedAt=now, accountStatus=deactivated. User is auto-excluded from queries but data remains in DB. Cannot soft-delete superadmins."
					},
