						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Student\",\n    \"email\": \"student@unistay.com\",\n    \"password\": \"password123\",\n    \"university\": \"University of Colombo\",\n    \"faculty\": \"Faculty of Science\",\n    \"academicYear\": \"3rd Year\",\n    \"studentId\": \"S2024001\",\n    \"address\": \"789 Student St, Colombo\",\n    \"age\": 22,\n    \"nic\": \"200298765432\",\n    \"phonenumber\": \"0770000000\"\n}",
