{
	"info": {
		"_postman_id": "unistay-user-management-v5",
		"name": "UniStay User Management API v5",
		"description": "Complete User Management API for UniStay. Roles: Student, Lecturer, Job Provider, SuperAdmin. Features: Multi-role registration, RBAC, profile management, admin dashboard with search/filter/pagination, account lifecycle (pending/active/suspended/deactivated), CSV & Excel export, and activity monitoring.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01. Registration",
			"description": "Public endpoints for user self-registration. Each role has a dedicated registration endpoint with role-specific validation.",
			"item": [
				{
					"name": "Register (Generic - defaults to Student)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Generic User\",\n    \"email\": \"generic@unistay.com\",\n    \"password\": \"password123\",\n    \"university\": \"University of Colombo\",\n    \"address\": \"123 Main St, Colombo\",\n    \"age\": 22,\n    \"nic\": \"200298765000\",\n    \"phonenumber\": \"0770000001\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/register",
							"host": ["{{baseUrl}}"],
							"path": ["users", "register"]
						},
						"description": "Generic registration endpoint. Defaults to student role. Use role-specific endpoints for better validation."
					},
					"response": []
				},
