# ─── Server ───────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your own)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Secrets ──────────────────────────────────────────────────
# Use long, random strings (at least 64 characters)
ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_token_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_token_secret
JWT_SECRET=replace_with_a_long_random_jwt_secret

# ─── Email (Nodemailer / Gmail App Password) ──────────────────────
USER_EMAIL=your_email@gmail.com
USER_PASS=your_gmail_app_password   # Generate at: https://myaccount.google.com/apppasswords

# ─── AI Services ──────────────────────────────────────────────────
GEMINI_API_KEY=replace_with_your_gemini_api_key
